# Copy this file to .env.local and fill in the values, then run `npm run dev`.
# .env.local is gitignored. Never commit real admin tokens.

# Base URL of the IntentGate gateway, e.g. http://localhost:8080
INTENTGATE_GATEWAY_URL=

# Shared admin secret. MUST match the gateway's INTENTGATE_ADMIN_TOKEN.
# Generate one with: openssl rand -hex 32
INTENTGATE_ADMIN_TOKEN=
